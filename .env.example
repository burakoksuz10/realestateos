APP_NAME="RE-OS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Istanbul
APP_URL=http://localhost

APP_LOCALE=tr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=tr_TR

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=reos
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=reos_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@reos.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_ORGANIZATION=

# Twilio Configuration
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# WhatsApp Business API
WHATSAPP_API_URL=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# SMS Provider (Netgsm, Iletimerkezi, etc.)
SMS_PROVIDER=netgsm
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=

# Portal Integrations
SAHIBINDEN_API_KEY=
SAHIBINDEN_API_SECRET=
HEPSIEMLAK_API_KEY=
HEPSIEMLAK_API_SECRET=
EMLAKJET_API_KEY=
EMLAKJET_API_SECRET=

# Payment Gateways
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
IYZICO_API_KEY=
IYZICO_SECRET_KEY=

# TKGM (Tapu Kadastro)
TKGM_API_URL=
TKGM_API_KEY=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Meta (Facebook/Instagram) Ads
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# Google Ads
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=

# E-Signature Provider
ESIGN_PROVIDER=onaylarim
ESIGN_API_KEY=
ESIGN_API_SECRET=

# 360 Virtual Tour
TOUR_360_PROVIDER=matterport
MATTERPORT_API_KEY=

# YouTube API
YOUTUBE_API_KEY=

# Bulutfon (VoIP)
BULUTFON_API_KEY=
BULUTFON_API_SECRET=
